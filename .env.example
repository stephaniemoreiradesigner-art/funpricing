# Supabase — obrigatório
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# URL pública da aplicação — usada para gerar links de propostas e e-mails
# Em produção: https://seudominio.com
# Em desenvolvimento: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# E-mail (SMTP) — usado para envio de confirmação de cadastro e redefinição de senha
# Funciona com Gmail, Outlook, Brevo, Hostinger, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_senha_de_app
EMAIL_FROM="Nome do Sistema <noreply@suaempresa.com.br>"
